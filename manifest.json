{
  "manifest_version": 3,
  "minimum_chrome_version": "113",
  "name": "WordPress Comment Assistant by Paradane",
  "version": "2.5.0",
  "description": "Drafts article-aware WordPress comments with OpenRouter and fills forms for review.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "alarms",
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://openrouter.ai/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "action": {
    "default_title": "WordPress Comment Assistant by Paradane",
    "default_icon": {
      "16": "icons/action16.png",
      "32": "icons/action32.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "dist/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
